rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user (including anonymous-auth users) can only read/write their own history.
    match /users/{userId}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Daily usage counters are read-only from the client. Only Cloud
    // Functions (Admin SDK, which bypasses these rules) may increment them —
    // this prevents a user from resetting their own quota.
    match /users/{userId}/usage/{date} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Achievement/badge star counts. Purely cosmetic (doesn't affect AI
    // quota or spend), so unlike usage/ this is fine to let the owner write
    // directly rather than routing through a Cloud Function.
    match /users/{userId}/stats/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
